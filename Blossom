<!DOCTYPE html>
<!-- Save this file as index.html for GitHub Pages -->
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Affordable social media management for small businesses with Blossom Social." />
  <title>Blossom Social</title>
  <style>
    :root {
      --bg: #fff8fb;
      --bg-soft: #fff1f7;
      --card: #ffffff;
      --pink: #e88db3;
      --pink-dark: #cc5d8f;
      --pink-light: #f8dce9;
      --text: #4f3b45;
      --muted: #7a6670;
      --border: #f2cddd;
      --shadow: 0 12px 30px rgba(204, 93, 143, 0.12);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, var(--bg) 0%, #ffffff 100%);
      color: var(--text);
      line-height: 1.6;
    }

    .container {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
    }

    .hero {
      padding: 88px 0 70px;
      text-align: center;
      background:
        radial-gradient(circle at top left, rgba(255,255,255,0.95), transparent 38%),
        linear-gradient(180deg, var(--bg-soft), var(--bg));
    }

    .eyebrow {
      display: inline-block;
      padding: 10px 18px;
      border-radius: 999px;
      background: #fff;
      border: 1px solid var(--border);
      color: var(--pink-dark);
      font-size: 0.95rem;
      font-weight: 600;
      box-shadow: var(--shadow);
      margin-bottom: 18px;
    }

    h1 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.6rem, 6vw, 4.8rem);
      color: var(--pink-dark);
      margin-bottom: 14px;
      font-style: italic;
    }

    .hero p {
      max-width: 760px;
      margin: 0 auto;
      color: var(--muted);
      font-size: 1.1rem;
    }

    .buttons {
      margin-top: 28px;
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 14px 22px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      transition: 0.2s ease;
    }

    .btn-primary {
      background: var(--pink-dark);
      color: white;
      box-shadow: var(--shadow);
    }

    .btn-secondary {
      background: white;
      color: var(--pink-dark);
      border: 1px solid var(--border);
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    section {
      padding: 70px 0;
    }

    .section-title {
      text-align: center;
      font-size: 2rem;
      margin-bottom: 10px;
      color: var(--text);
    }

    .section-subtext {
      text-align: center;
      max-width: 740px;
      margin: 0 auto 34px;
      color: var(--muted);
    }

    .promo {
      max-width: 760px;
      margin: 0 auto 28px;
      background: linear-gradient(135deg, #fff, var(--pink-light));
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 22px;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .promo strong {
      color: var(--pink-dark);
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      box-shadow: var(--shadow);
    }

    .card h3 {
      font-size: 1.4rem;
      margin-bottom: 8px;
    }

    .card p.plan-text {
      color: var(--muted);
      min-height: 54px;
    }

    .price {
      font-size: 2.7rem;
      font-weight: 800;
      color: var(--pink-dark);
      margin: 18px 0 6px;
    }

    .price span {
      font-size: 1rem;
      color: var(--muted);
      font-weight: 600;
    }

    ul.features {
      list-style: none;
      margin-top: 18px;
    }

    ul.features li {
      position: relative;
      padding-left: 22px;
      margin-bottom: 10px;
      color: var(--text);
    }

    ul.features li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--pink-dark);
      font-weight: 900;
    }

    .addon,
    .contact-box,
    .info-grid .info-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow);
    }

    .addon {
      max-width: 760px;
      margin: 28px auto 0;
      text-align: center;
      padding: 26px;
    }

    .addon h3 {
      margin-bottom: 8px;
    }

    .addon-price {
      font-size: 2.4rem;
      color: var(--pink-dark);
      font-weight: 800;
      margin: 8px 0;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .info-card {
      padding: 24px;
    }

    .info-card h4 {
      margin-bottom: 8px;
      font-size: 1.1rem;
    }

    .info-card p {
      color: var(--muted);
    }

    .contact-box {
      max-width: 780px;
      margin: 0 auto;
      padding: 34px 24px;
      text-align: center;
    }

    .contact-box p {
      margin-bottom: 10px;
      font-size: 1.04rem;
    }

    .contact-box a {
      color: var(--pink-dark);
      font-weight: 700;
      text-decoration: none;
    }

    footer {
      padding: 30px 0 50px;
      text-align: center;
      color: var(--muted);
      font-size: 0.95rem;
    }

    @media (max-width: 900px) {
      .pricing-grid,
      .info-grid {
        grid-template-columns: 1fr;
      }

      .hero {
        padding-top: 70px;
      }
    }
  </style>
</head>
<body>
  <header class="hero">
    <div class="container">
      <div class="eyebrow">Affordable social media management for small businesses</div>
      <h1>Blossom Social</h1>
      <p>
